{
  "$schema": "https://opencode.ai/config.json",
{{- if eq .chezmoi.username "shi-han.ng" }}
  "provider": {
      "litellm": {
          "npm": "@ai-sdk/openai-compatible",
          "name": "LiteLLM",
          "options": {
              "baseURL": "{{- onepasswordRead "op://Personal/LiteLLM/hostname" -}}/v1"
          },
          "models": {
              "bedrock-ap-southeast-2/global.anthropic.claude-haiku-4-5-20251001-v1:0": {
                  "name": "bedrock-ap-southeast-2/global.anthropic.claude-haiku-4-5-20251001-v1:0",
                  "attachment": true,
                  "reasoning": true,
                  "tool_call": true,
                  "temperature": true,
                  "interleaved": { "field": "reasoning_content" },
                  "modalities": {
                    "input": ["text", "image", "pdf"],
                    "output": ["text"]
                  },
                  "limit": {
                    "context": 200000,
                    "output": 64000
                  },
                  "cost": {
                    "input": 1,
                    "output": 5,
                    "cache_read": 0.1,
                    "cache_write": 1.25
                  }
              },
              "bedrock-ap-southeast-2/global.anthropic.claude-opus-4-8": {
                  "name": "bedrock-ap-southeast-2/global.anthropic.claude-opus-4-8",
                  "attachment": true,
                  "reasoning": true,
                  "tool_call": true,
                  "temperature": false,
                  "interleaved": { "field": "reasoning_content" },
                  "modalities": {
                    "input": ["text", "image", "pdf"],
                    "output": ["text"]
                  },
                  "limit": {
                    "context": 1000000,
                    "output": 128000
                  },
                  "cost": {
                    "input": 5,
                    "output": 25,
                    "cache_read": 0.5,
                    "cache_write": 6.25
                  },
                  "options": {
                    "thinking": { "type": "adaptive" },
                    "output_config": { "effort": "high" }
                  }
              },
              "bedrock-ap-southeast-2/global.anthropic.claude-sonnet-4-6": {
                  "name": "bedrock-ap-southeast-2/global.anthropic.claude-sonnet-4-6",
                  "attachment": true,
                  "reasoning": true,
                  "tool_call": true,
                  "temperature": true,
                  "interleaved": { "field": "reasoning_content" },
                  "modalities": {
                    "input": ["text", "image", "pdf"],
                    "output": ["text"]
                  },
                  "limit": {
                    "context": 1000000,
                    "output": 64000
                  },
                  "cost": {
                    "input": 3,
                    "output": 15,
                    "cache_read": 0.3,
                    "cache_write": 3.75
                  }
              }
          }
      }
  },
  "model": "litellm/bedrock-ap-southeast-2/global.anthropic.claude-sonnet-4-6",
  "agent": {
      "plan": {
          "model": "litellm/bedrock-ap-southeast-2/global.anthropic.claude-sonnet-4-6",
          "permission": {
            "bash": { "*": "ask", "git *": "allow" },
            "nvim_*": "allow"
          }
      },
      "build": {
          "model": "litellm/bedrock-ap-southeast-2/global.anthropic.claude-sonnet-4-6"
      },
      "code-reviewer": {
          "model": "litellm/bedrock-ap-southeast-2/global.anthropic.claude-opus-4-8",
          "permission": {
            "bash": { "*": "ask", "git *": "allow" }
          }
      },
      "commit-author": {
          "model": "litellm/bedrock-ap-southeast-2/global.anthropic.claude-haiku-4-5-20251001-v1:0"
      },
      "content-proofreader": {
          "model": "litellm/bedrock-ap-southeast-2/global.anthropic.claude-haiku-4-5-20251001-v1:0",
          "temperature": 0.2
      }
  },
  {{ else }}
  "model": "github-copilot/claude-sonnet-4.6",
  "agent": {
    "plan": {
      "model": "github-copilot/claude-sonnet-4.6"
    },
    "build": {
      "model": "github-copilot/claude-sonnet-4.6"
    }
  },
  {{ end -}}
  "default_agent": "plan",
  "plugin": ["@mohak34/opencode-notifier@latest"],
  "mcp": {
    "memory": {
      "type": "local",
      "command": ["mcp-server-memory"],
      "enabled": true,
      "environment": {
        "MEMORY_FILE_PATH": "~/memory.json"
      }
    },
    "vectorcode-mcp-server": {
      "type": "local",
      "command": ["vectorcode-mcp-server"],
      "enabled": false
    },
    "context7": {
      "type": "local",
      "command": ["context7-mcp"],
      "enabled": true
    },
    "astro_doc": {
      "type": "remote",
      "url": "https://mcp.docs.astro.build/mcp",
      "enabled": false
    },
    "shadcn": {
      "type": "local",
      "command": ["shadcn", "mcp"],
      "enabled": false
    },
    "opentofu": {
      "type": "local",
      "command": ["opentofu-mcp-server"],
      "enabled": false
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["mcp-server-sequential-thinking"],
      "enabled": true
    },
    "dbhub-postgres-npx": {
      "type": "local",
      "command": [
        "dbhub",
        "--transport",
        "stdio",
        "--dsn",
        "postgres://postgres@localhost:5432/postgres?sslmode=disable"
      ],
      "enabled": false
    },
    "chrome": {
      "type": "local",
      "command": [
        "chrome-devtools-mcp",
        "--no-usage-statistics",
        "--isolated",
        "--headless"
      ],
      "enabled": false
    },
    "nvim": {
      "type": "local",
      "command": [
        "nvim-mcp",
        "--connect",
        "auto"
      ],
      "enabled": true
    }
  },
  "lsp": {
    "pyright": {
      "disabled": true
    },
    "zuban": {
      "command": ["zuban", "server"],
      "extensions": [".py", ".pyi"]
    }
  }
}
